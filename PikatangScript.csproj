<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWPF>true</UseWPF>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>PikatangScript</AssemblyName>
    <RootNamespace>PikatangScript</RootNamespace>
    <Version>1.0.0</Version>
    <AssemblyTitle>PikatangScript</AssemblyTitle>
    <Description>网页游戏脚本工具</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.3912.50" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Assets\" />
    <Folder Include="Core\" />
    <Folder Include="UI\ViewModels\" />
  </ItemGroup>

</Project>
