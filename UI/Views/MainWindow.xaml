<Window x:Class="PikatangScript.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="皮卡堂脚本" Height="700" Width="1100">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="160"/>
        </Grid.RowDefinitions>

        <!-- 左侧功能侧边栏 -->
        <Border Grid.Column="0" Grid.Row="0" Background="#F5F5F7" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <TabControl x:Name="SidebarTabs" Background="Transparent" BorderThickness="0">

                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="TabBorder" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" BorderThickness="0,0,0,2" BorderBrush="Transparent">
                                        <ContentPresenter ContentSource="Header" HorizontalAlignment="Left"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="#0078D4"/>
                                            <Setter Property="Foreground" Value="#0078D4"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter TargetName="TabBorder" Property="Background" Value="#fff"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="TabBorder" Property="Background" Value="#fff"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>
                <TabItem Header="脚本功能">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">

                    </ScrollViewer>
                </TabItem>
                <TabItem Header="设置">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="关于" Margin="0,0,0,0" Width="NaN">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                       
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Border>

        <!-- 右侧内嵌浏览器 -->
        <Border Grid.Column="1" Grid.Row="0" Background="White">
            <wv2:WebView2 x:Name="Browser" Source="about:blank"/>
        </Border>

        <!-- 下方日志控制台 -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="#F0F0F0" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                    <TextBlock Text="日志控制台" FontSize="12" FontWeight="SemiBold" Foreground="#666" VerticalAlignment="Center" Margin="12,0,0,0"/>
                </Border>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="LogConsole" Foreground="#333" FontFamily="Consolas" FontSize="12" Padding="12,8" LineHeight="20"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>